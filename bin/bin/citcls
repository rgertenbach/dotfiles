#!/usr/bin/env python3

# Finds all currently active Piper / Fig Clients and exported CLs.
#
# CLOUDTOP ONLY
#
# Typical usage example:
#   citcls  # Gets your own workspaces and cls
#   citcls ${username}  # Gets the workspaces and cls of a user

import argparse
import collections
import os
import re
#from yachalk import chalk
from typing import Optional

class Workspace:
  # Each CL workspace has a bit specifying the type, source and change.
  _FIG_CL_RE = re.compile(r'^fig-export-(.*)-(?:\d+?\-)change-(\d+)$')
  _CS_CL_RE = re.compile(r'^CS-(.*)-\d{4}-\d\d-\d\d_\d+$')

  def __init__(self, ws: str):
    self.name = ws
    self.parent = self.parse_parent(ws)

  @property
  def is_parent(self) -> bool:
    return self.parent is None

  @classmethod
  def parse_parent(cls, workspace: str) -> Optional[str]:
    if matches := cls._FIG_CL_RE.findall(workspace):
      return matches[0][0]
    elif matches := cls._CS_CL_RE.findall(workspace):
      return matches[0]
    else:
      return None


def main():
  user: str = os.environ.get('USER') if args.user is None else args.user
  folders = os.listdir(os.path.join('/google/src/cloud', user))
  workspaces = [Workspace(ws) for ws in folders]
  hier = collections.defaultdict(list)

  for ws in workspaces:
    _ = hier[ws.name] if ws.is_parent else hier[ws.parent].append(ws.name)

  hier = {k: hier[k] for k in sorted(hier.keys())}

  for ws, cls in hier.items():
    print(ws)
    # print(chalk.bold(ws))
    for cl in cls:
      print(f' ↳ {cl}')


if __name__ == '__main__':
  parser = argparse.ArgumentParser(description='List CitC workspaces and CLs')
  parser.add_argument('user', type=str, default=None, nargs='?',
                      metavar='User Name', help='user name, $USER if None.')
  args = parser.parse_args()
  main()
