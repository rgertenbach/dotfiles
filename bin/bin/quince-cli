#!/bin/bash

/usr/local/google/home/rgertenbach/mpms/quince-cli/cli.par \
  "$@" \
  --gfs_user='bulk-email-ads-override'

ret=$?

if [[ "${ret}" -ne 0 ]]; then
  exit "${ret}"
fi

while [[ "$#" -gt 0 ]]; do
  if [[ $1 == '--email' ]]; then
    echo 'The user should be able to receive these emails again.'
    exit 0
  fi
  shift
done
